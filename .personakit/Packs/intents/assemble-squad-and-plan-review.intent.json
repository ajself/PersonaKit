{
  "id": "assemble-squad-and-plan-review",
  "version": "1.0",
  "name": "Assemble Squad And Plan Review",
  "description": "Turn an objective into a staffed plan with explicit role coverage and gates.",
  "parameters": [
    {
      "name": "objective",
      "type": "string",
      "required": true
    },
    {
      "name": "workspaceScope",
      "type": "string",
      "required": false
    },
    {
      "name": "currentArtifactPaths",
      "type": "string[]",
      "required": false
    },
    {
      "name": "knownPersonaIds",
      "type": "string[]",
      "required": false
    },
    {
      "name": "constraints",
      "type": "string[]",
      "required": false
    },
    {
      "name": "definitionOfDone",
      "type": "string[]",
      "required": false
    },
    {
      "name": "confidenceThreshold",
      "type": "number",
      "required": false
    },
    {
      "name": "requiredValidationCommands",
      "type": "string[]",
      "required": false
    },
    {
      "name": "delegatedRoleNames",
      "type": "string[]",
      "required": false
    },
    {
      "name": "groundingArtifactPaths",
      "type": "string[]",
      "required": false
    },
    {
      "name": "planningOutputPath",
      "type": "string",
      "required": false
    }
  ],
  "includesEssentialIds": [
    "delegated-agent-handoff-template",
    "multiagent-squad-planning-contract",
    "persona-hiring-routing-contract",
    "squad-planning-report-template",
    "squad-planning-log-contract",
    "partner-trust-contract",
    "worktree-squad-gating-contract",
    "non-goals",
    "tools-and-constraints"
  ],
  "requiresSkillIds": [
    "codex-cli"
  ],
  "risk": {
    "level": "medium",
    "requiresHumanReview": true,
    "notes": [
      "Do not turn planning recommendations into implementation without AJ review.",
      "Require explicit owners, definition of done, and validation before execution handoff.",
      "Delegated lanes need compact handoff packets with grounding path, write scope, validation, and stop points.",
      "Static-export fallback is only for bounded implementation or review work; otherwise stop as `grounding-blocked`.",
      "Pause before structural pack updates or execution handoff."
    ]
  }
}
