{
  "id": "reverse-interview-persona-fit",
  "version": "1.0",
  "name": "Reverse Interview Persona Fit",
  "description": "Assess role fit for a persona candidate and identify the highest-value missing artifacts.",
  "parameters": [
    {
      "name": "personaId",
      "type": "string",
      "required": true
    },
    {
      "name": "roleContext",
      "type": "string",
      "required": true
    },
    {
      "name": "requiredCapabilities",
      "type": "string[]",
      "required": false
    },
    {
      "name": "riskProfile",
      "type": "string",
      "required": false
    },
    {
      "name": "focusAreas",
      "type": "string[]",
      "required": false
    },
    {
      "name": "confidenceThreshold",
      "type": "number",
      "required": false
    },
    {
      "name": "outputReportPath",
      "type": "string",
      "required": false
    }
  ],
  "includesEssentialIds": [
    "persona-hiring-standards",
    "persona-hiring-research-loop",
    "persona-hiring-log-contract",
    "partner-trust-contract",
    "non-goals",
    "tools-and-constraints"
  ],
  "requiresSkillIds": [
    "codex-cli"
  ],
  "risk": {
    "level": "medium",
    "requiresHumanReview": true,
    "notes": [
      "Role-fit analysis is not approval to change candidate artifacts.",
      "Keep missing-artifact recommendations explicit, bounded, and prioritized.",
      "Run the research loop before any low-confidence verdict.",
      "Write report and JSONL outputs before concluding.",
      "Pause for AJ approval before structural pack or session changes."
    ]
  }
}
