{
  "id": "git-history-garden-review",
  "version": "1.0",
  "name": "Git History Garden Review",
  "description": "Assess commit history quality, propose bounded pruning actions, and record deterministic decision traces.",
  "parameters": [
    {
      "name": "commitRange",
      "type": "string",
      "required": true
    },
    {
      "name": "focusAreas",
      "type": "string[]",
      "required": false
    },
    {
      "name": "logPath",
      "type": "string",
      "required": false
    }
  ],
  "includesEssentialIds": [
    "pack-gardening-standards",
    "gardening-log-contract",
    "git-history-gardening-standards",
    "non-goals",
    "tools-and-constraints"
  ],
  "requiresSkillIds": [
    "codex-cli"
  ],
  "risk": {
    "level": "medium",
    "requiresHumanReview": true,
    "notes": [
      "Do not rewrite history without explicit approval.",
      "Log every decision before proposing commit-level actions."
    ]
  }
}
