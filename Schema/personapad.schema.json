{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/personapad.schema.json",
  "title": "PersonaPad Schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentType"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "documentType": {
      "type": "string",
      "enum": [
        "personaPack",
        "persona"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "personaPack"
          }
        }
      },
      "then": {
        "required": [
          "pack",
          "personas"
        ],
        "properties": {
          "pack": {
            "type": "object",
            "required": [
              "id",
              "name"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "author": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "homepage": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "defaults": {
            "type": "object",
            "properties": {
              "outputFormat": {
                "type": "string",
                "enum": [
                  "markdown",
                  "text",
                  "json"
                ]
              },
              "modelHint": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "personas": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/persona"
            }
          }
        },
        "additionalProperties": true
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "persona"
          }
        }
      },
      "then": {
        "required": [
          "persona"
        ],
        "properties": {
          "persona": {
            "$ref": "#/$defs/persona"
          }
        },
        "additionalProperties": true
      }
    }
  ],
  "$defs": {
    "persona": {
      "type": "object",
      "required": [
        "id",
        "name",
        "system"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "system": {
          "type": "string"
        },
        "template": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string"
            },
            "sections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "key",
                  "label",
                  "required"
                ],
                "properties": {
                  "key": {
                    "type": "string",
                    "minLength": 1
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "placeholder": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "outputContract": {
          "type": "object",
          "properties": {
            "headings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "askClarifyingQuestionsMax": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "unevaluatedProperties": true
}
