{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intentTemplate.schema.json",
  "title": "IntentTemplate",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "type",
          "required"
        ]
      }
    },
    "includesEssentialIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresSkillIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string"
        },
        "requiresHumanReview": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "level",
        "requiresHumanReview",
        "notes"
      ]
    }
  },
  "required": [
    "id",
    "version",
    "name",
    "description",
    "parameters",
    "includesEssentialIds",
    "requiresSkillIds",
    "risk"
  ]
}
