{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.schema.json",
  "title": "Task",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "requiresReview": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "text"
        ]
      }
    },
    "requiresIntentTemplateIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresSkillIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "version",
    "title",
    "goal",
    "steps",
    "acceptanceCriteria",
    "verification",
    "requiresIntentTemplateIds",
    "requiresSkillIds"
  ]
}
