{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill.schema.json",
  "title": "Skill",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "providedBy": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "read-only-inspection",
          "edit-files",
          "run-commands",
          "network-access",
          "autonomous-loop"
        ]
      }
    },
    "triggerRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pathGlobs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skillTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": []
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string"
        },
        "requiresHumanReview": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "level",
        "requiresHumanReview",
        "notes"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "version",
    "name",
    "description"
  ]
}
