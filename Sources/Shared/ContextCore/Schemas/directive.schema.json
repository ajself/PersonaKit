{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directive.schema.json",
  "title": "Directive",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "requiresReview": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "text"
        ]
      }
    },
    "requiresSkillIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "type",
          "required"
        ]
      }
    },
    "risk": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string"
        },
        "requiresHumanReview": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "level",
        "requiresHumanReview",
        "notes"
      ]
    },
    "workstream": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "entrySessionId": {
          "type": "string"
        },
        "requiredCloseoutSessionId": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sessionId": {
                "type": "string"
              },
              "phase": {
                "type": "string"
              }
            },
            "required": [
              "sessionId",
              "phase"
            ]
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "fromSessionId": {
                "type": "string"
              },
              "toSessionId": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "required-next",
                  "required-closeout",
                  "optional-follow-up"
                ]
              }
            },
            "required": [
              "fromSessionId",
              "toSessionId",
              "kind"
            ]
          }
        }
      },
      "required": [
        "id",
        "phase",
        "entrySessionId",
        "nodes",
        "edges"
      ]
    }
  },
  "required": [
    "id",
    "version",
    "title",
    "goal",
    "steps",
    "acceptanceCriteria",
    "verification",
    "requiresSkillIds"
  ]
}
