{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/gardening-recommendations.schema.json",
  "title": "Gardening Recommendation JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "rankingSetId",
    "phaseLabel",
    "summary",
    "targetIds",
    "riskScore",
    "driftImpactScore",
    "urgencyScore",
    "effortScore",
    "scoreModel",
    "totalScore",
    "priority",
    "rank",
    "whyNow",
    "expectedImpact",
    "status",
    "evidenceRefs",
    "nextAction",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^GREC-[0-9]{3}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "rankingSetId": {
      "type": "string",
      "minLength": 1
    },
    "phaseLabel": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "targetIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "driftImpactScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "urgencyScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "effortScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "scoreModel": {
      "type": "string",
      "const": "R3-I3-U2-E1"
    },
    "totalScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 45
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "rank": {
      "type": "integer",
      "minimum": 1
    },
    "whyNow": {
      "type": "string",
      "minLength": 1
    },
    "expectedImpact": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "deferred",
        "rejected",
        "executed"
      ]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
