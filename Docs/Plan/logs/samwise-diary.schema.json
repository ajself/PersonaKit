{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/samwise-diary.schema.json",
  "title": "Samwise Daily Diary JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "summary",
    "whatShipped",
    "whatLearned",
    "improvements",
    "nextGoals",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^SWD-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "const": "samwise-daily-closeout"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "whatShipped": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whatLearned": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextGoals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    }
  }
}
