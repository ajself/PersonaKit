{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/gardening-health-snapshots.schema.json",
  "title": "Gardening Health Snapshot JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "phaseLabel",
    "windowLabel",
    "totalEvents",
    "recentEvents",
    "openBacklogItems",
    "recommendationAcceptedCount",
    "recommendationDeferredCount",
    "recommendationRejectedCount",
    "topRiskAreas",
    "recommendedFocusAreas",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^GHS-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "phaseLabel": {
      "type": "string",
      "minLength": 1
    },
    "windowLabel": {
      "type": "string",
      "enum": [
        "all-time",
        "rolling-7",
        "rolling-30"
      ]
    },
    "totalEvents": {
      "type": "integer",
      "minimum": 0
    },
    "recentEvents": {
      "type": "integer",
      "minimum": 0
    },
    "openBacklogItems": {
      "type": "integer",
      "minimum": 0
    },
    "recommendationAcceptedCount": {
      "type": "integer",
      "minimum": 0
    },
    "recommendationDeferredCount": {
      "type": "integer",
      "minimum": 0
    },
    "recommendationRejectedCount": {
      "type": "integer",
      "minimum": 0
    },
    "topRiskAreas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedFocusAreas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
