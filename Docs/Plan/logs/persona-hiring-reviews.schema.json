{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/persona-hiring-reviews.schema.json",
  "title": "Persona Hiring Review JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "personaId",
    "roleContext",
    "verdict",
    "confidencePercent",
    "thresholdPercent",
    "strengths",
    "gaps",
    "unknowns",
    "evidenceRefs",
    "recommendations",
    "firstStep",
    "reportPath",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^PHR-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "const": "samwise-persona-hiring"
    },
    "personaId": {
      "type": "string",
      "minLength": 1
    },
    "roleContext": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "qualified",
        "qualified-with-gaps",
        "not-yet-qualified"
      ]
    },
    "confidencePercent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "thresholdPercent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "description"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "essentials",
        "kits",
        "intents",
        "directives",
        "sessions"
      ],
      "properties": {
        "essentials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "directives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "firstStep": {
      "type": "string",
      "minLength": 1
    },
    "reportPath": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
