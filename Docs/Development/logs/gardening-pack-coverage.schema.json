{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/gardening-pack-coverage.schema.json",
  "title": "Gardening Pack Coverage Snapshot JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "phaseLabel",
    "counts",
    "unresolvedReferenceCount",
    "unresolvedReferences",
    "coverageStatus",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^GCV-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "phaseLabel": {
      "type": "string",
      "minLength": 1
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "personas",
        "kits",
        "directives",
        "intents",
        "skills",
        "essentials",
        "sessions"
      ],
      "properties": {
        "personas": { "type": "integer", "minimum": 0 },
        "kits": { "type": "integer", "minimum": 0 },
        "directives": { "type": "integer", "minimum": 0 },
        "intents": { "type": "integer", "minimum": 0 },
        "skills": { "type": "integer", "minimum": 0 },
        "essentials": { "type": "integer", "minimum": 0 },
        "sessions": { "type": "integer", "minimum": 0 }
      }
    },
    "unresolvedReferenceCount": {
      "type": "integer",
      "minimum": 0
    },
    "unresolvedReferences": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverageStatus": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
