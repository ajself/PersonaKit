{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/git-history-gardener-log.schema.json",
  "title": "Git History Gardener JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "phaseLabel",
    "scope",
    "category",
    "subject",
    "commitRange",
    "candidateCommit",
    "proposedAction",
    "decision",
    "rationale",
    "affectedArtifacts",
    "validationStatus",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^GHG-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "const": "git-history-gardener"
    },
    "phaseLabel": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "const": "git-history"
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "commitRange": {
      "type": "string",
      "minLength": 1
    },
    "candidateCommit": {
      "type": "string",
      "minLength": 1
    },
    "proposedAction": {
      "type": "string",
      "enum": [
        "keep",
        "squash",
        "fixup-followup",
        "drop-proposal",
        "doc-only"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected",
        "deferred"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "affectedArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validationStatus": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "not-run"
      ]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    }
  }
}
