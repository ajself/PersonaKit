{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/worktree-squad-loops.schema.json",
  "title": "Worktree Squad Loop Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "objective",
    "worktreeBranch",
    "authorizationMode",
    "gateId",
    "status",
    "verificationCommands",
    "verificationStatus",
    "reviewSummary",
    "residualRisks",
    "nextActions"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^WSQ-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "enum": [
        "samwise-worktree-squad-oversight",
        "worktree-squad-delivery"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "worktreeBranch": {
      "type": "string",
      "minLength": 1
    },
    "authorizationMode": {
      "type": "string",
      "enum": [
        "per-commit-approval",
        "worktree-auto-commit-approved"
      ]
    },
    "gateId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "in-progress",
        "completed",
        "blocked"
      ]
    },
    "verificationCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verificationStatus": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail",
        "blocked"
      ]
    },
    "reviewSummary": {
      "type": "string",
      "minLength": 1
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
