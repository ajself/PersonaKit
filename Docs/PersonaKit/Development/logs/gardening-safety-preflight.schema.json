{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/gardening-safety-preflight.schema.json",
  "title": "Gardening Safety Preflight JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "phaseLabel",
    "laneBranch",
    "integrationBranch",
    "reviewGateCount",
    "requiresHumanReviewIntents",
    "blockedActions",
    "status",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^GSP-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "phaseLabel": {
      "type": "string",
      "minLength": 1
    },
    "laneBranch": {
      "type": "string",
      "minLength": 1
    },
    "integrationBranch": {
      "type": "string",
      "minLength": 1
    },
    "reviewGateCount": {
      "type": "integer",
      "minimum": 0
    },
    "requiresHumanReviewIntents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockedActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
