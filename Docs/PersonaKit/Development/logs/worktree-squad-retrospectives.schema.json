{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/worktree-squad-retrospectives.schema.json",
  "title": "Worktree Squad Retrospective Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "entryType",
    "objective",
    "actionItems",
    "reportPath",
    "reviewer"
  ],
  "oneOf": [
    {
      "required": [
        "keepDoing",
        "lessOf",
        "moreOf",
        "stopDoing",
        "startDoing"
      ]
    },
    {
      "required": [
        "whatWentWell",
        "whatDidNot",
        "openQuestions",
        "improvements"
      ]
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "entryType": {
            "const": "retrospective"
          },
          "sessionId": {
            "const": "worktree-squad-retrospective"
          }
        },
        "required": [
          "entryType",
          "sessionId"
        ]
      },
      "then": {
        "oneOf": [
          {
            "required": [
              "whatWentWell",
              "whatDidNot",
              "openQuestions",
              "improvements"
            ]
          },
          {
            "required": [
              "keepDoing",
              "lessOf",
              "moreOf",
              "stopDoing",
              "startDoing",
              "retrospectiveMethod",
              "declaredRoles",
              "actualParticipants",
              "participantEvidencePaths",
              "subagentCount",
              "featureConfidence",
              "productConfidence",
              "processConfidence"
            ]
          }
        ]
      }
    }
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^WSR-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "enum": [
        "rosie-retrospective-garden",
        "worktree-squad-retrospective"
      ]
    },
    "entryType": {
      "type": "string",
      "enum": [
        "recommendation",
        "retrospective"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "keepDoing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lessOf": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "moreOf": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stopDoing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "startDoing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whatWentWell": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whatDidNot": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retrospectiveMethod": {
      "type": "string",
      "enum": [
        "fan-out",
        "hybrid",
        "roundtable"
      ]
    },
    "declaredRoles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actualParticipants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "participantEvidencePaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "subagentCount": {
      "type": "integer",
      "minimum": 0
    },
    "featureConfidence": {
      "type": "string",
      "enum": [
        "high",
        "low",
        "medium"
      ]
    },
    "productConfidence": {
      "type": "string",
      "enum": [
        "high",
        "low",
        "medium"
      ]
    },
    "processConfidence": {
      "type": "string",
      "enum": [
        "high",
        "low",
        "medium"
      ]
    },
    "reportPath": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
