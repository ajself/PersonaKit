{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/session-stack-reviews.schema.json",
  "title": "Session Stack Review JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "date",
    "sessionId",
    "objective",
    "targetSessionId",
    "sourceRefType",
    "reportPath",
    "currentOverallConfidence",
    "projectedOverallConfidence",
    "verdict",
    "blockerCount",
    "mcpStatus",
    "reviewer"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^SSR-[0-9]{4}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "const": "samwise-session-stack-review"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "targetSessionId": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefType": {
      "type": "string",
      "enum": ["id", "path"]
    },
    "reportPath": {
      "type": "string",
      "minLength": 1
    },
    "currentOverallConfidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 10
    },
    "projectedOverallConfidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 10
    },
    "verdict": {
      "type": "string",
      "enum": ["safe", "caution", "unsafe", "blocked"]
    },
    "blockerCount": {
      "type": "integer",
      "minimum": 0
    },
    "mcpStatus": {
      "type": "string",
      "enum": ["pass", "gap", "unavailable"]
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
