{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personakit.local/schemas/partner-handoffs.schema.json",
  "title": "Partner Handoff Event JSONL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "handoffId",
    "date",
    "sessionId",
    "title",
    "ownerRef",
    "writeScope",
    "acceptanceCriteria",
    "risks",
    "status",
    "eventType"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^PHF-[0-9]{4}$"
    },
    "handoffId": {
      "type": "string",
      "pattern": "^HOF-[0-9]{3}$"
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "ownerRef": {
      "type": "string",
      "minLength": 1
    },
    "writeScope": {
      "type": "string",
      "minLength": 1
    },
    "acceptanceCriteria": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
