{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcodebuild: Build Debug PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-workspace",
        "PersonaPad.xcworkspace",
        "-scheme",
        "PersonaPadApp",
        "-configuration",
        "Debug",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xcodebuild: Build Release PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-workspace",
        "PersonaPad.xcworkspace",
        "-scheme",
        "PersonaPadApp",
        "-configuration",
        "Release",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xcodebuild: Run PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-workspace",
        "PersonaPad.xcworkspace",
        "-scheme",
        "PersonaPadApp",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
