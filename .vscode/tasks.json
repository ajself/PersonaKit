{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "xcodebuild: Build Debug PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-scheme",
        "PersonaPadApp",
        "-configuration",
        "Debug",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xcodebuild: Build Release PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-scheme",
        "PersonaPadApp",
        "-configuration",
        "Release",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "xcodebuild: Run PersonaPadApp",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-scheme",
        "PersonaPadApp",
        "-destination",
        "platform=macOS",
        "-derivedDataPath",
        ".build/DerivedData",
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "swift: Build Debug personapad",
      "type": "shell",
      "command": "swift",
      "args": [
        "build",
        "-c",
        "debug",
        "--product",
        "personapad"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "swift: Build Release personapad",
      "type": "shell",
      "command": "swift",
      "args": [
        "build",
        "-c",
        "release",
        "--product",
        "personapad"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "swift: Build Debug personapad-validate",
      "type": "shell",
      "command": "swift",
      "args": [
        "build",
        "-c",
        "debug",
        "--product",
        "personapad-validate"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "swift: Build Release personapad-validate",
      "type": "shell",
      "command": "swift",
      "args": [
        "build",
        "-c",
        "release",
        "--product",
        "personapad-validate"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
