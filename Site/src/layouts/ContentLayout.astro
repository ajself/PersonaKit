---
import SiteLayout from "./SiteLayout.astro";

interface Props {
  description: string;
  eyebrow?: string;
  title: string;
}

const {
  description,
  eyebrow,
  title,
} = Astro.props;
---

<SiteLayout title={title} description={description}>
  <main class="content-page">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="lede">{description}</p>
    <div class="content-body">
      <slot />
    </div>
  </main>
</SiteLayout>

<style>
  .content-page {
    padding: 48px 0 72px;
  }

  .content-body {
    max-width: 880px;
    margin-top: 32px;
  }

  .eyebrow {
    margin-bottom: 10px;
    color: var(--accent);
    font-weight: 750;
    text-transform: uppercase;
    font-size: 13px;
  }
</style>
