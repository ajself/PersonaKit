---
import { sitePath } from "../utils/sitePath";

const links = [
  { href: sitePath("start-here/"), label: "Start Here" },
  { href: sitePath("learn/"), label: "Learn" },
  { href: sitePath("when-to-use/"), label: "When To Use" },
  { href: sitePath("examples/"), label: "Examples" },
];
---

<header class="site-header">
  <nav class="shell" aria-label="Primary navigation">
    <a class="brand" href={sitePath()} aria-label="PersonaKit home">
      <span class="brand-mark" aria-hidden="true">
        <img class="brand-icon" src={sitePath("brand/personakit-mark.svg")} alt="" />
      </span>
      <span>PersonaKit</span>
    </a>
    <div class="links">
      {
        links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))
      }
      <a class="repo-link" href="https://github.com/ajself/PersonaKit" aria-label="PersonaKit on GitHub">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24">
          <path d="M12 1C5.923 1 1 5.923 1 12c0 4.867 3.149 8.979 7.521 10.436.55.096.756-.233.756-.522 0-.262-.013-1.128-.013-2.049-2.764.509-3.479-.674-3.699-1.292-.124-.317-.66-1.293-1.127-1.554-.385-.207-.936-.715-.014-.729.866-.014 1.485.797 1.691 1.128.99 1.663 2.571 1.196 3.204.907.096-.715.385-1.196.701-1.471-2.448-.275-5.005-1.224-5.005-5.432 0-1.196.426-2.186 1.128-2.956-.111-.275-.496-1.402.11-2.915 0 0 .921-.288 3.024 1.128A10.193 10.193 0 0 1 12 6.308c.936 0 1.871.123 2.75.371 2.104-1.43 3.025-1.128 3.025-1.128.605 1.513.221 2.64.111 2.915.701.77 1.127 1.747 1.127 2.956 0 4.222-2.571 5.157-5.019 5.432.399.344.743 1.004.743 2.035 0 1.471-.014 2.654-.014 3.025 0 .289.206.632.756.522C19.851 20.979 23 16.854 23 12c0-6.077-4.922-11-11-11Z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(12px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 62px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--accent);
  }

  .brand-icon {
    display: block;
    width: 16px;
    height: 21px;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .links a {
    min-height: 34px;
    padding: 6px 9px;
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--ink);
    font-weight: 650;
    text-decoration: none;
  }

  .repo-link {
    display: inline-grid !important;
    place-items: center;
    width: 34px !important;
    height: 34px;
    padding: 0 !important;
    border-color: var(--line) !important;
  }

  .repo-link svg {
    display: block;
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .links a:hover {
    border-color: var(--line);
    color: var(--blue);
    background: #fff;
  }

  @media (max-width: 700px) {
    nav {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 12px;
    }

    .links {
      justify-content: flex-start;
    }
  }
</style>
