---
interface Props {
  alt: string;
  caption?: string;
  src: string;
}

const {
  alt,
  caption,
  src,
} = Astro.props;
---

<figure>
  <img src={src} alt={alt} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  figure {
    margin: 0;
    max-width: 100%;
    overflow-x: auto;
    overscroll-behavior-x: contain;
  }

  img {
    display: block;
    width: max(100%, 760px);
    min-height: 240px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
  }
</style>
